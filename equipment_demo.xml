<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data noupdate="1">
        <record id="cat_cpu" model="equipment.category"><field name="code">CPU</field><field name="name">Vi xử lý (CPU)</field></record>
        <record id="cat_ram" model="equipment.category"><field name="code">RAM</field><field name="name">Bộ nhớ trong (RAM)</field></record>
        <record id="cat_vga" model="equipment.category"><field name="code">VGA</field><field name="name">Card màn hình (VGA)</field></record>
        <record id="cat_main" model="equipment.category"><field name="code">MAIN</field><field name="name">Bo mạch chủ (Mainboard)</field></record>

        <record id="brand_asus" model="equipment.brand"><field name="name">ASUS</field><field name="hotline">1800-6588</field></record>
        <record id="brand_msi" model="equipment.brand"><field name="name">MSI</field></record>
        <record id="brand_intel" model="equipment.brand"><field name="name">Intel</field></record>

        <record id="supp_1" model="equipment.partner"><field name="name">Nhà phân phối Viết Sơn</field><field name="is_supplier">True</field><field name="is_customer">False</field></record>
        <record id="cust_1" model="equipment.partner"><field name="name">Nguyễn Văn A</field><field name="phone">0909123456</field><field name="membership_tier">silver</field><field name="points">150</field></record>

        <record id="prod_vga" model="equipment.product">
            <field name="default_code">RTX-4070</field><field name="name">VGA ASUS Dual RTX 4070</field>
            <field name="category_id" ref="cat_vga"/><field name="brand_id" ref="brand_asus"/>
            <field name="warranty">36</field><field name="standard_price">15000000</field><field name="price">16500000</field>
        </record>
        <record id="prod_cpu" model="equipment.product">
            <field name="default_code">I5-13400F</field><field name="name">CPU Intel Core i5-13400F</field>
            <field name="category_id" ref="cat_cpu"/><field name="brand_id" ref="brand_intel"/>
            <field name="warranty">36</field><field name="standard_price">4500000</field><field name="price">5200000</field>
        </record>

        <record id="inv_in_vga" model="equipment.inventory"><field name="product_id" ref="prod_vga"/><field name="type">in</field><field name="reason">purchase</field><field name="quantity">2</field><field name="state">done</field></record>
        <record id="inv_in_cpu" model="equipment.inventory"><field name="product_id" ref="prod_cpu"/><field name="type">in</field><field name="reason">purchase</field><field name="quantity">50</field><field name="state">done</field></record>

        <record id="warranty_1" model="equipment.warranty">
            <field name="name">SN-ASUS-RTX4070-001</field>
            <field name="product_id" ref="prod_vga"/>
            <field name="partner_id" ref="cust_1"/>
            <field name="purchase_date">2024-01-15</field>
            <field name="end_date">2027-01-15</field>
            <field name="state">valid</field>
        </record>
    </data>
